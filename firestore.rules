rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function me() { return request.auth.uid; }
    function myUserPath() { return /databases/$(database)/documents/users/$(me()); }
    function myUserExists() { return signedIn() && exists(myUserPath()); }
    function myRank() { return myUserExists() ? get(myUserPath()).data.rank : null; }
    function isAdmin() { return myRank() == "admin"; }
    function isHangaround() { return myRank() == "hangaround"; }
    function canReadFullApp() { return signedIn() && !isHangaround(); }
    function isOfficer() {
      return myRank() in ["president", "vice_president", "sergeant_at_arms"] || isAdmin();
    }
    function canPostInfos() {
      return myRank() in ["president", "vice_president", "sergeant_at_arms", "secretary"] || isAdmin();
    }
    function canManageCalendar() {
      return myRank() in ["road_captain", "president", "vice_president", "sergeant_at_arms"] || isAdmin();
    }
    function validCalendarDay() {
      return request.resource.data.keys().hasOnly([
        "date", "month", "destination", "time", "endTime", "cost", "meetPoint",
        "type", "note", "required", "maxParticipants", "routeLink", "contact",
        "status", "createdBy", "createdAt", "updatedBy", "updatedAt", "doneBy", "doneAt"
      ])
      && request.resource.data.date is string
      && request.resource.data.month is string
      && request.resource.data.destination is string
      && request.resource.data.destination.size() > 0
      && request.resource.data.destination.size() <= 160
      && request.resource.data.time is string
      && request.resource.data.endTime is string
      && request.resource.data.meetPoint is string
      && request.resource.data.note is string
      && request.resource.data.routeLink is string
      && request.resource.data.contact is string
      && request.resource.data.type in ["ausfahrt", "treffen", "tour", "sitzung", "aktion", "sonstiges"]
      && request.resource.data.status in ["open", "done"]
      && request.resource.data.required is bool
      && request.resource.data.cost is number
      && request.resource.data.cost >= 0
      && request.resource.data.maxParticipants is number
      && request.resource.data.maxParticipants >= 0;
    }

    match /users/{userId} {
      allow read: if signedIn() && (userId == me() || !isHangaround());
      allow create: if false;
      allow update: if signedIn() && (
        isAdmin()
        || (isOfficer()
          && resource.data.rank != "admin"
          && request.resource.data.rank != "admin")
        || (userId == me()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["name"]))
      );
      allow delete: if signedIn() && isAdmin();
    }

    match /settings/{settingId} {
      allow read: if canReadFullApp();
      allow write: if signedIn() && isOfficer();
    }
    match /app_settings/{settingId} {
      allow read: if canReadFullApp();
      allow write: if signedIn() && isOfficer();
    }
    match /buttons/{buttonId} {
      allow read: if canReadFullApp();
      allow write: if signedIn() && isOfficer();
    }
    match /editable_buttons/{buttonId} {
      allow read: if canReadFullApp();
      allow write: if signedIn() && isOfficer();
    }

    match /infos/{infoId} {
      allow read: if canReadFullApp();
      allow create: if signedIn() && canPostInfos()
                    && request.resource.data.createdBy == me();
      allow update, delete: if signedIn() && (
        (resource.data.createdBy == me() && canPostInfos()) || isOfficer()
      );
    }

    match /changelog/{logId} {
      allow read: if canReadFullApp();
      allow create, update, delete: if signedIn() && isAdmin();
    }

    match /calendar_days/{dayId} {
      allow read: if signedIn();
      allow create: if signedIn() && canManageCalendar()
                    && validCalendarDay()
                    && request.resource.data.date == dayId
                    && request.resource.data.createdBy == me();
      allow update: if signedIn() && canManageCalendar()
                    && validCalendarDay()
                    && request.resource.data.date == dayId
                    && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if signedIn() && canManageCalendar();

      match /rsvps/{uid} {
        allow read: if signedIn();
        allow create, update: if signedIn()
                              && uid == me()
                              && request.resource.data.keys().hasOnly(["uid", "name", "status", "updatedAt"])
                              && request.resource.data.uid == me()
                              && request.resource.data.status in ["confirmed", "declined"];
        allow delete: if signedIn() && uid == me();
      }
    }

    // Member Only wurde aus der Vollversion entfernt.
    match /member_only_profiles/{document=**} { allow read, write: if false; }
    match /member_only_messages/{document=**} { allow read, write: if false; }

    match /{document=**} { allow read, write: if false; }
  }
}
